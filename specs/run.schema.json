{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$defs": {
        "#CodeState": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "base_commit": {
                    "type": "string",
                    "pattern": "^[a-f0-9]{40}$"
                },
                "patch": {
                    "$ref": "#/$defs/#Patch"
                },
                "repo_url": {
                    "type": "string"
                }
            },
            "required": [
                "base_commit",
                "repo_url"
            ]
        },
        "#Exec": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "argv": {
                    "allOf": [
                        {
                            "prefixItems": [
                                true
                            ]
                        },
                        {
                            "type": "array",
                            "items": {
                                "type": "string"
                            },
                            "minLength": 1
                        }
                    ]
                },
                "cwd": {
                    "type": "string"
                },
                "env": {
                    "type": "object",
                    "additionalProperties": {
                        "type": "string"
                    }
                },
                "timeout_sec": {
                    "type": "integer"
                }
            },
            "required": [
                "argv",
                "cwd"
            ]
        },
        "#Patch": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "ref": {
                    "type": "string",
                    "pattern": "^refs/patches/"
                },
                "sha256": {
                    "type": "string",
                    "pattern": "^[a-f0-9]{64}$"
                }
            },
            "required": [
                "ref",
                "sha256"
            ]
        },
        "#LogRef": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "path": {
                    "type": "string"
                }
            },
            "required": [
                "path"
            ]
        },
        "#Timeline": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "created_at": {
                    "type": "string",
                    "format": "date-time"
                },
                "started_at": {
                    "type": "string",
                    "format": "date-time"
                },
                "ended_at": {
                    "type": "string",
                    "format": "date-time"
                }
            }
        }
    },
    "type": "object",
    "additionalProperties": false,
    "properties": {
        "code_state": {
            "$ref": "#/$defs/#CodeState"
        },
        "exec": {
            "$ref": "#/$defs/#Exec"
        },
        "run_id": {
            "type": "string",
            "pattern": "^run_[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
        },
        "run_version": {
            "const": 0
        },
        "status": {
            "type": "string",
            "enum": ["pending", "running", "exited", "failed", "killed"],
            "default": "pending"
        },
        "runtime": {
            "type": "string",
            "enum": ["background", "tmux", "zellij"],
            "default": "background"
        },
        "session_ref": {
            "type": "string",
            "description": "Runtime-specific session reference (e.g., 'tmux:session=runbox;window=run_xxx')"
        },
        "log_ref": {
            "$ref": "#/$defs/#LogRef"
        },
        "timeline": {
            "$ref": "#/$defs/#Timeline"
        },
        "exit_code": {
            "type": "integer"
        },
        "pid": {
            "type": "integer",
            "description": "Process ID for background runtime"
        }
    },
    "required": [
        "code_state",
        "exec",
        "run_id"
    ]
}
